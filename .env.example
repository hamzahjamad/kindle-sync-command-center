# Application log file (default: ./sync.log next to the app; Docker Compose sets /data/komga/app.log on the volume).
# APP_LOG_FILE=

# Komga HTTP API (required for download)
# Public reverse-proxy URL (resolves from anywhere) or internal Docker URL, e.g. http://komga:25600
KOMGA_BASE_URL=https://komga.hamzahjamad.com
KOMGA_USERNAME=admin@example.com
KOMGA_PASSWORD=change-me

# Optional: limit to specific libraries (comma-separated IDs). Leave empty for all.
KOMGA_LIBRARY_IDS=

# File types to download (comma-separated, no dots)
KOMGA_ALLOWED_EXTENSIONS=epub,pdf,cbz

# Optional: host path mounted in the container for default snapshot/binary paths
KOMGA_SOURCE_DIR=

# Snapshot JSON (default: /data/komga/komga_library_snapshot.json or under KOMGA_SOURCE_DIR)
KOMGA_LIBRARY_DB_PATH=

# Pagination / HTTP
KOMGA_DB_PAGE_SIZE=200
KOMGA_HTTP_TIMEOUT_SECONDS=120
KOMGA_LIBRARY_REFRESH_ON_START=false

# When true, also GET /api/v1/books/{id}/file for each book into KOMGA_BINARIES_DIR
KOMGA_DOWNLOAD_BINARIES=true
KOMGA_BINARIES_DIR=
KOMGA_BINARIES_SKIP_UNCHANGED=true
# When true (default), each downloaded book lives under readable folders:
# ``LibraryTitle__<libraryId>/SeriesTitle__<seriesId>/BookTitle__<bookId>/media.<ext>``.
# Canonical Komga ids stay after the final ``__`` so the catalog and UI still match.
# Set to false to use the old layout: ``<libraryId>/<seriesId>/<bookId>/``.
KOMGA_BINARIES_HUMAN_DIRS=true
# Slug-only folders (``Manga/Bleach/Chapter_1/``) with ``.komga.json`` storing Komga ids — no ``__id`` in names.
# Set false to keep ``Title__<id>`` directory names instead.
KOMGA_BINARIES_PLAIN_SLUGS=true
# When true (default), each book file is named ``00042 - Chapter Title.ext`` (sortable in KOReader) instead of ``media.ext``.
KOMGA_KOREADER_FILENAMES=true
KOMGA_FILE_DOWNLOAD_TIMEOUT=600

# Cron expression for docker-compose sidecar: POST /komga/library/refresh
KOMGA_LIBRARY_CRON_SCHEDULE=0 */6 * * *

# --- Kindle storage stats (SSH poller when KINDLE_IP is set) ---
KINDLE_IP=192.168.69.113
# KINDLE_USER=root
# DEST_DIR=/mnt/us/documents
# With SSH_KEY_PATH unset, the app uses password SSH with an empty password (typical Kindle/dropbear). Set KINDLE_PASSWORD for a non-empty password, or SSH_KEY_PATH for key-based auth.
# KINDLE_PASSWORD=
# SSH_KEY_PATH=
# SSH_TIMEOUT_SECONDS=12
# KINDLE_STATS_INTERVAL_SECONDS=30
